<div class="message">
  <%= flash[:notice] %>
</div>
<div class="show-contents">
  <p>
    <span class="show-title">Title:</span>
    <span><%= @book.title %></span>
  </p>

  <p>
    <span class="show-title">Body:</span>
    <span><%= @book.body %></span>
  </p>
</div>
<div class="edit-button">
  <%= link_to "Edit", edit_book_path(@book.id) %>
  <span>|</span>
  <%= link_to "Back", books_path %>
</div>